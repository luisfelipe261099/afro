# ── Neon (PostgreSQL serverless) ─────────────────────────────────────────
# Painel do Neon > Project > Connect > "Connection string"
# Formato: postgresql://<user>:<senha>@<host>/<db>?sslmode=require
DATABASE_URL="postgresql://neondb_owner:senha@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Google Gemini (lido automaticamente pelo @ai-sdk/google) ─────────────
# Chave: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY="..."

# ── Sessão / JWT ─────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
JWT_SECRET="troque-isto-por-um-segredo-longo-e-aleatorio"
